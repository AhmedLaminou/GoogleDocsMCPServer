# Google OAuth client JSON (prefer a hosting secret manager)
GOOGLE_CLIENT_SECRET_JSON=

# Paths are resolved by the application; use persistent storage in production.
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# External HTTPS origin, without a trailing slash.
PUBLIC_BASE_URL=http://localhost:8000

# Optional locally; strongly recommended for any public deployment.
MCP_API_KEY=
MCP_SESSION_SECRET=
ALLOWED_HOSTS=localhost,127.0.0.1
COOKIE_SECURE=false

PORT=8000
