# Optional self-hosted overrides. Normal package users need none of these.
GOOGLE_DOCS_MCP_CONFIG_DIR=
GOOGLE_CREDENTIALS_FILE=
GOOGLE_TOKEN_FILE=

# "default" = documents + drive.file
# "full" = documents + restricted full Drive
GOOGLE_DOCS_MCP_SCOPE_PROFILE=default

# Optional hosted SSE settings.
PUBLIC_BASE_URL=http://localhost:8000
MCP_API_KEY=
MCP_SESSION_SECRET=
ALLOWED_HOSTS=localhost,127.0.0.1
COOKIE_SECURE=false
PORT=8000
